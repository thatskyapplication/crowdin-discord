		"@sentry/cloudflare": "^10.9.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@cloudflare/workers-types": "^4.20250701.0",
		"typescript": "^6.0.3",
		"wrangler": "^4.22.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=26",
			"onFail": "error"
